{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "sveltekit",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "redirects": [
    {
      "source": "/paadugajaala",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/paadugajaala/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/virtual_piano.html",
      "destination": "/piano",
      "permanent": true
    }
  ]
}
